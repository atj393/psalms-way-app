<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme used once React Native has loaded. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
    </style>

    <!--
        Splash screen theme — applied to MainActivity before the JS bundle loads.
        The window background is shown immediately by the OS with zero delay.
        MainActivity.kt switches back to AppTheme in onCreate() so the splash
        disappears as soon as React Native is ready to render.
    -->
    <style name="SplashTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:statusBarColor">@color/splashBackground</item>
        <item name="android:navigationBarColor">@color/splashBackground</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/splashBackground</item>
    </style>

</resources>
